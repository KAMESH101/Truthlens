{
  "name": "truthlens-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && venv\\Scripts\\python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev": "npm run dev:all"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
